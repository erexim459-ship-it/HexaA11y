{
  "manifest_version": 3,
  "name": "HexaA11y",
  "version": "1.0.0",
  "description": "Widget de acessibilidade flutuante para qualquer site.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "HexaA11y"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
